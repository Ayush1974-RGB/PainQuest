# ─── Application ─────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for WebSocket CORS and socket client)
# In development, leave blank — the app auto-detects window.location.origin
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# WebSocket server URL (defaults to NEXT_PUBLIC_APP_URL or window.location.origin)
NEXT_PUBLIC_WS_URL=https://your-app.vercel.app

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for the custom Node.js server (default: 3000)
PORT=3000

# Host binding (default: 0.0.0.0)
HOST=0.0.0.0
